{
  "name": "pi-pulse",
  "version": "0.3.5",
  "type": "module",
  "description": "Live TPS, TTFT, and response-time footer for the pi coding agent.",
  "license": "MIT",
  "author": {
    "name": "codegiveness",
    "url": "https://github.com/codegiveness"
  },
  "homepage": "https://github.com/codegiveness/pi-pulse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codegiveness/pi-pulse.git"
  },
  "bugs": {
    "url": "https://github.com/codegiveness/pi-pulse/issues"
  },
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "extension",
    "tps",
    "ttft",
    "tokens-per-second",
    "time-to-first-token",
    "performance",
    "footer"
  ],
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension.d.ts",
      "default": "./dist/extension.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "scripts": {
    "build": "./node_modules/typescript/bin/tsc",
    "typecheck": "./node_modules/typescript/bin/tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "pretest": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test",
    "release": "node node_modules/@changesets/cli/bin.js publish"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "typescript": "^6.0.3"
  }
}
